{
  "builds": [
    {
      "src": "api/**/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/py-convert",
      "dest": "/api/convert.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
